[importlinter]
root_packages =
    runner
    execution
    evaluator
    exec_eval
    parse
    reconstructor
    llm
    live_metrics
    constants
    prompts

[importlinter:contract:evaluator-isolation]
name = evaluator must not import execution or runner
type = forbidden
source_modules =
    evaluator
forbidden_modules =
    execution
    runner

[importlinter:contract:parse-purity]
name = parse must not import llm, execution, or evaluator
type = forbidden
source_modules =
    parse
forbidden_modules =
    llm
    execution
    evaluator

[importlinter:contract:reconstructor-purity]
name = reconstructor must not import llm, execution, or evaluator
type = forbidden
source_modules =
    reconstructor
forbidden_modules =
    llm
    execution
    evaluator

[importlinter:contract:constants-purity]
name = constants must not import any pipeline module
type = forbidden
source_modules =
    constants
forbidden_modules =
    runner
    execution
    evaluator
    exec_eval
    parse
    llm
    live_metrics
